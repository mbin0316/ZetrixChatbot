      "parameters": {
        "promptType": "define",
        "text": "={{ $json.query || $json.input }}",
        "options": {
          "systemMessage": "=You are a Malaysian Household Income data assistant.\nYou ONLY answer questions about DOSM household income statistics.\n\nWhen calling the household_income_data tool, always pass a specific query that includes:\n- The exact state/district/constituency name\n- The year\n- The level (state, district, parlimen, or dun)\n- The metric (mean or median)\n\nExample: if asked \"median income johor 2022\", call the tool with:\n\"Johor state mean median household income 2022 hh_income_state\"\n\nRULES:\n1. Always cite the source file and year.\n2. If not found, say: 'I cannot find that information in the dataset.'\n3. Never invent figures.\n4. Format as RM followed by number (e.g. RM6,276).\n5. Always end with: 'Data source: DOSM | open.dosm.gov.my | CC BY 4.0'"
        }
      },
      "id": "89eab251-a6b8-49a0-ac88-5e29f91b7b9c",
      "name": "LLM Generation",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        224,
        0
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "model": "qwen/qwen3-32b",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        192,
        288
      ],
      "id": "21e6dc8c-53c9-4d7d-b639-f76df412b849",
      "name": "Groq Chat Model",
      "credentials": {
        "groqApi": {
          "id": "YfHuuubObUh4UdwX",
          "name": "Groq account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const query = $input.first().json.query || '';\n\nconst states = ['Johor','Kedah','Kelantan','Melaka','Negeri Sembilan',\n  'Pahang','Perak','Perlis','Pulau Pinang','Sabah','Sarawak',\n  'Selangor','Terengganu','W.P. Kuala Lumpur','W.P. Labuan','W.P. Putrajaya'];\n\nconst yearMatch = query.match(/\\b(2019|2020|2022|2024)\\b/);\nconst year  = yearMatch ? yearMatch[1] : null;\nconst state = states.find(s => query.toLowerCase().includes(s.toLowerCase()));\n\n// Get embedding\nconst embedRes = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'http://localhost:11434/api/embeddings',\n  headers: { 'Content-Type': 'application/json' },\n  body: JSON.stringify({ model: 'nomic-embed-text', prompt: query })\n});\nconst embedding = embedRes.embedding;\n\n// Build filter — only add conditions we are sure about\nconst must = [];\nif (state) must.push({ key: \"metadata.state\", match: { value: state }});\nif (year)  must.push({ key: \"metadata.year\",  match: { value: year }});\n\n// Search Qdrant\nconst searchRes = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'http://localhost:6333/collections/hh_income/points/search',\n  headers: { 'Content-Type': 'application/json' },\n  body: JSON.stringify({\n    vector: embedding,\n    limit: 8,\n    with_payload: true,\n    filter: must.length > 0 ? { must } : undefined\n  })\n});\n\nconst context = searchRes.result.map((r, i) =>\n  `[${i+1}] ${r.payload.page_content}`\n).join('\\n\\n');\n\nreturn [{ json: { context, query, startTime: Date.now() } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -48,
        416
      ],
      "id": "c2b952a3-1050-4677-9300-dc3ae019de44",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "let answer = $input.first().json.answer || $input.first().json.output || $input.first().json.text || '';\n\n// Remove <think>...</think> blocks\nanswer = answer.replace(/<think>[\\s\\S]*?<\\/think>/gi, '').trim();\n\n// Remove \"Calling tool...\" lines\nanswer = answer.replace(/Calling tool.*?\\n/gi, '').trim();\n\n// Remove \"Calling tool\" lines that don't end in \\n\nanswer = answer.replace(/Calling tool[^\\n]*/gi, '').trim();\n\nreturn [{ json: { \n  answer, \n  query: $input.first().json.query || $('Intent Check').first().json.query || '',\n  latencyMs: Date.now() - ($input.first().json.startTime || Date.now()),\n  timestamp: new Date().toISOString()\n}}];"
      },
