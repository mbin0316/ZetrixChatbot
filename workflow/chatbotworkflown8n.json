    {
      "parameters": {
        "jsCode": "  const response  = $json.response || '';\n  const query     = $json.query || '';\n  const latencyMs = $json.latencyMs || 0;\n\n  // Clean up the response and ensure citation footer is present\n  let finalResponse = response.trim();\n\n  if (!finalResponse.includes('open.dosm.gov.my')) {\n    finalResponse += '\\n\\n---\\nData source: DOSM | open.dosm.gov.my | CC BY 4.0';\n  }\n\n  return [{\n    json: {\n      query: query,\n      answer: finalResponse,\n      latencyMs: latencyMs,\n      timestamp: new Date().toISOString(),\n    }\n  }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
